{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["client", "admin", "employee"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Service": {
      "title": "Service",
      "description": "Digital service offered on the platform",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "image": { "type": "string" },
        "features": { "type": "array", "items": { "type": "string" } },
        "active": { "type": "boolean" },
        "expertId": { "type": "string" },
        "expertName": { "type": "string" }
      },
      "required": ["title", "description", "price", "category"]
    },
    "Category": {
      "title": "Category",
      "description": "Service categories",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "icon": { "type": "string" },
        "color": { "type": "string" },
        "count": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name"]
    },
    "Order": {
      "title": "Order",
      "description": "Service booking/order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "clientId": { "type": "string" },
        "guestName": { "type": "string" },
        "guestEmail": { "type": "string" },
        "guestPhone": { "type": "string" },
        "projectDetails": { "type": "string" },
        "serviceId": { "type": "string" },
        "serviceTitle": { "type": "string" },
        "price": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "paid", "in-progress", "completed", "cancelled"] },
        "paymentId": { "type": "string" },
        "assignedExpertId": { "type": "string" },
        "assignedExpertName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clientId", "serviceId", "price", "status"]
    },
    "Review": {
      "title": "Review",
      "description": "User review for a service",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "serviceId": { "type": "string" },
        "clientId": { "type": "string" },
        "clientName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["serviceId", "clientId", "rating"]
    },
    "Message": {
      "title": "Message",
      "description": "Chat message between client and admin",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "receiverId": { "type": "string" },
        "text": { "type": "string" },
        "orderId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "receiverId", "text"]
    },
    "ContactMessage": {
      "title": "ContactMessage",
      "description": "Message sent from the contact form",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["new", "read", "replied"] },
        "replyContent": { "type": "string" },
        "repliedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "subject", "message", "status"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Platform-wide settings",
      "type": "object",
      "properties": {
        "platformName": { "type": "string" },
        "supportEmail": { "type": "string" },
        "maintenanceMode": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["platformName", "supportEmail"]
    },
    "Testimonial": {
      "title": "Testimonial",
      "description": "Client testimonials",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "content": { "type": "string" },
        "avatar": { "type": "string" },
        "rating": { "type": "number" },
        "featured": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "content", "rating"]
    },
    "TeamMember": {
      "title": "TeamMember",
      "description": "Team members/experts",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "bio": { "type": "string" },
        "image": { "type": "string" },
        "specialties": { "type": "array", "items": { "type": "string" } },
        "social": { "type": "object", "properties": { "linkedin": { "type": "string" }, "twitter": { "type": "string" } } },
        "active": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "role", "bio"]
    },
    "NewsletterSubscription": {
      "title": "NewsletterSubscription",
      "description": "User email for newsletter subscription",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "createdAt"]
    }
  },
  "firestore": {
    "/users/{uid}": { "schema": "User", "description": "User profiles" },
    "/services/{serviceId}": { "schema": "Service", "description": "Available services" },
    "/orders/{orderId}": { "schema": "Order", "description": "Service orders" },
    "/reviews/{reviewId}": { "schema": "Review", "description": "Service reviews" },
    "/messages/{messageId}": { "schema": "Message", "description": "Chat messages" },
    "/contact_messages/{messageId}": { "schema": "ContactMessage", "description": "Contact form submissions" },
    "/categories/{categoryId}": { "schema": "Category", "description": "Service categories" },
    "/settings/config": { "schema": "Settings", "description": "Global platform configuration" },
    "/testimonials/{testimonialId}": { "schema": "Testimonial", "description": "Client testimonials" },
    "/team/{memberId}": { "schema": "TeamMember", "description": "Team members" },
    "/newsletter_subscriptions/{subscriptionId}": { "schema": "NewsletterSubscription", "description": "Newsletter subscriptions" }
  }
}
