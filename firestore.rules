rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: uid
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - photoURL: string (optional)
    //   - role: string (required, 'client' or 'admin')
    //   - createdAt: timestamp (required)
    //
    // Collection: services
    // Document ID: serviceId
    // Fields:
    //   - title: string (required)
    //   - description: string (required)
    //   - price: number (required)
    //   - category: string (required)
    //   - image: string (optional)
    //   - features: list (optional)
    //   - active: bool (required)
    //
    // Collection: orders
    // Document ID: orderId
    // Fields:
    //   - clientId: string (required)
    //   - serviceId: string (required)
    //   - serviceTitle: string (required)
    //   - price: number (required)
    //   - status: string (required, 'pending', 'paid', 'in-progress', 'completed', 'cancelled')
    //   - paymentId: string (optional)
    //   - createdAt: timestamp (required)
    //   - updatedAt: timestamp (required)
    //
    // Collection: reviews
    // Document ID: reviewId
    // Fields:
    //   - serviceId: string (required)
    //   - clientId: string (required)
    //   - clientName: string (required)
    //   - rating: number (required)
    //   - comment: string (optional)
    //   - createdAt: timestamp (required)
    //
    // Collection: messages
    // Document ID: messageId
    // Fields:
    //   - senderId: string (required)
    //   - receiverId: string (required)
    //   - text: string (required)
    //   - orderId: string (optional)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "mk.rabbani.cse@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidUser(data) {
      return data.uid is string && data.uid.size() > 0 &&
             data.email is string && data.email.size() > 0 &&
             data.role in ['client', 'admin'];
    }

    function isValidService(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.description is string && data.description.size() > 0 && data.description.size() < 2000 &&
             data.price is number && data.price >= 0 &&
             data.category in ['MERN Stack', 'WordPress', 'Video Editing', 'Digital Marketing'] &&
             data.active is bool;
    }

    function isValidOrder(data) {
      return data.clientId is string && data.clientId.size() > 0 &&
             data.serviceId is string && data.serviceId.size() > 0 &&
             data.price is number && data.price >= 0 &&
             data.status in ['pending', 'paid', 'in-progress', 'completed', 'cancelled'];
    }

    function isValidReview(data) {
      return data.serviceId is string && data.serviceId.size() > 0 &&
             data.clientId is string && data.clientId.size() > 0 &&
             data.rating is number && data.rating >= 1 && data.rating <= 5;
    }

    function isValidMessage(data) {
      return data.senderId is string && data.senderId.size() > 0 &&
             data.receiverId is string && data.receiverId.size() > 0 &&
             data.text is string && data.text.size() > 0 && data.text.size() < 5000;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create: if isOwner(uid) && isValidUser(request.resource.data) && (request.resource.data.role == 'client' || isAdmin());
      allow update: if isOwner(uid) && isValidUser(request.resource.data) && (request.resource.data.role == resource.data.role || isAdmin());
    }

    match /services/{serviceId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && isValidService(request.resource.data);
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.clientId) || isAdmin());
      allow create: if isAuthenticated() && isOwner(request.resource.data.clientId) && isValidOrder(request.resource.data);
      allow update: if isAuthenticated() && (isOwner(resource.data.clientId) || isAdmin()) && isValidOrder(request.resource.data);
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated() && isOwner(request.resource.data.clientId) && isValidReview(request.resource.data);
      allow update, delete: if isAuthenticated() && (isOwner(resource.data.clientId) || isAdmin());
    }

    match /messages/{messageId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.senderId) || isOwner(resource.data.receiverId) || isAdmin());
      allow create: if isAuthenticated() && isOwner(request.resource.data.senderId) && isValidMessage(request.resource.data);
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
